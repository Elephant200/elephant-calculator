{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate": {
      "dependsOn": ["^generate"],
      "outputs": ["openapi.json", "src/index.d.ts"]
    },
    "lint": {
      "dependsOn": ["^generate"]
    },
    "test": {
      "dependsOn": ["^generate"]
    }
  }
}
