{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^generate"],
      "outputs": []
    },
    "@elephant-calculator/web#build": {
      "dependsOn": ["^build", "^generate"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate": {
      "dependsOn": ["^generate"],
      "outputs": []
    },
    "@elephant-calculator/api#generate": {
      "dependsOn": ["^generate"],
      "outputs": ["openapi.json"]
    },
    "@elephant-calculator/api-contract#generate": {
      "dependsOn": ["^generate"],
      "outputs": ["openapi.json", "src/index.d.ts"]
    },
    "lint": {
      "dependsOn": ["^generate"]
    },
    "test": {
      "dependsOn": ["^generate"]
    }
  }
}
