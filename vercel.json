{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @elephant-calculator/web build",
  "outputDirectory": "apps/web/.next",
  "functions": {
    "api/index.py": {
      "includeFiles": "{apps/api/src/**,packages/calculator/src/**}",
      "maxDuration": 30
    }
  },
  "rewrites": [{ "source": "/api/:path*", "destination": "/api/index" }]
}
