{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "echo 'No build step for the Python API'",
  "installCommand": "pip install -r requirements.txt",
  "functions": {
    "api/index.py": {
      "includeFiles": "{apps/api/src/**,packages/calculator/src/**}",
      "maxDuration": 30
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }]
}
